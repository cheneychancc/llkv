{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    // Extra safety for array and object lookups, but may have false positives.
    "noUncheckedIndexedAccess": true,

    // Path mapping for cleaner imports.
    "paths": {
      "@/*": ["./src/*"],
      "@lichtblick/suite": ["./src/suite/index.ts"],
      "@lichtblick/suite/*": ["./src/suite/*"],
      "@lichtblick/suite-base": ["./src/suite-base/index.ts"],
      "@lichtblick/suite-base/*": ["./src/suite-base/*"],
      "@lichtblick/mcap-support": ["./src/mcap-support/index.ts"],
      "@lichtblick/mcap-support/*": ["./src/mcap-support/*"]
    },

    // `vue-tsc --build` produces a .tsbuildinfo file for incremental type-checking.
    // Specified here to keep it out of the root directory.
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    // verbatimModuleSyntax 是 TypeScript 的一个编译选项
    // 开启后要求：如果导入的是类型（type），必须显式使用 import type 语法，不能用普通的 import
    "verbatimModuleSyntax": false,
    "moduleResolution": "node"
  }
}
